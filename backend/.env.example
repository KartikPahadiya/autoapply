# App's own API credentials (not user data — one set for the whole server)
APIFY_API_TOKEN=
HUGGINGFACEHUB_API_TOKEN=
HUNTER_API_KEY=

# Laddro Career MCP server (resume tailoring / cover letter generation).
# The bearer token is your Smithery/Laddro account's own credential — one
# for the whole app, same treatment as the other API keys above.
LADDRO_MCP_URL=https://mcp.smithery.run/kartikpahadiya122004
LADDRO_MCP_API_KEY=

# NVIDIA API key — the resume-tailoring sub-agent is routed to
# nvidia/nemotron-3-ultra-550b-a55b via this key, separate from the main
# chat agent's HuggingFace-hosted LLM.
NVIDIA_API_KEY=

# Google OAuth client — from Google Cloud Console > APIs & Services > Credentials
# GOOGLE_REDIRECT_URI must exactly match an Authorized redirect URI registered
# there (scheme, host, port, path all matter). Use your real domain, not
# localhost, once deployed.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://yourapp.com/auth/google/callback

# Where your frontend lives, and where to send the browser after a
# successful login redirect completes.
FRONTEND_ORIGIN=https://yourapp.com
FRONTEND_POST_LOGIN_URL=https://yourapp.com/dashboard

# Set to "false" ONLY for local http:// testing. Must be "true" in any
# real deployment (cookies over HTTPS) or the session cookie won't be
# sent/stored reliably by browsers.
COOKIE_SECURE=true
